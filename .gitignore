# Dependencies and package-manager noise
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment
.env
.env.*
!.env.example

# OS/editor files
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/

