*.log
*.tmp
p5-gysin-demo.svg
p5-gysin-demo.json
gysin.svg
gysin.json

# Keep project metadata tracked even when a global gitignore ignores it.
!info.json
!docs/info.json
!examples/info.json

# Important: p5.gysin.min.js is a committed distribution file.
!p5.gysin.min.js

